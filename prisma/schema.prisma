generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Sito {
  id              String            @id @default(cuid())
  nome            String
  dominio         String            @unique
  istruzioni      String    // linee guida di scrittura per questo sito
  categorie       String[]  // categorie specifiche del sito
  wpSiteUrl       String?
  wpUsername      String?
  wpAppPassword   String?
  sessioni        Session[]
  linkAnalysisJobs LinkAnalysisJob[]
}

model Session {
  id                 String       @id @default(cuid())
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  stato              StatoSession @default(IN_ATTESA)
  tipo               SessioneTipo @default(CREAZIONE)
  sitoId             String?
  sito               Sito?        @relation(fields: [sitoId], references: [id])
  categoria          String
  argomento          String
  fonti              String[]
  ricercaJson        Json?
  wpPostId           Int?
  wpPostUrl          String?
  wpPostType         String?    @default("post")
  contenutoOriginale String?
  focusAggiornamento String?
  linkInterni        LinkInterno[]
  articoli           Articolo[]
  jobs               Job[]
}

model LinkInterno {
  id        String  @id @default(cuid())
  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  testo     String
  url       String
}

model Articolo {
  id             String        @id @default(cuid())
  createdAt      DateTime      @default(now())
  sessionId      String
  session        Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  slug           String        @unique
  titolo         String
  stato          StatoArticolo @default(BOZZA)
  pubblicatoIl   DateTime?
  wpPostId       Int?
  versioneScelta String?
  versioni       Versione[]
}

model Versione {
  id                String   @id @default(cuid())
  articoloId        String
  articolo          Articolo @relation(fields: [articoloId], references: [id], onDelete: Cascade)
  indice            Int
  tono              String
  corpo             String
  noteRevisione     String?
  seoJson           Json     @default("{}")
  immagineUrl       String?
  immagineCreditUrl String?
  punteggio         Float?
}

model Job {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  sessionId    String
  session      Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  stato        StatoJob @default(IN_CODA)
  fase         String?
  errore       String?
  completatoIl DateTime?
}

enum StatoSession {
  IN_ATTESA
  IN_CORSO
  COMPLETATA
  FALLITA
}

enum SessioneTipo {
  CREAZIONE
  AGGIORNAMENTO
}

enum StatoArticolo {
  BOZZA
  REVISIONE
  APPROVATO
  PUBBLICATO
}

enum StatoJob {
  IN_CODA
  IN_ESECUZIONE
  COMPLETATO
  FALLITO
}

model LinkAnalysisJob {
  id             String           @id @default(cuid())
  sitoId         String
  sito           Sito             @relation(fields: [sitoId], references: [id], onDelete: Cascade)
  stato          String           @default("in_coda") // in_coda | in_corso | completato | errore
  fase           String           @default("in_coda") // in_coda | fetch | analisi | completato | errore
  progresso      Int              @default(0)
  totalePost     Int              @default(0)
  postProcessati Int              @default(0)
  errore         String?
  suggestions    LinkSuggestion[]
  creatoIl       DateTime         @default(now())
  aggiornatoIl   DateTime         @updatedAt
}

model LinkSuggestion {
  id           String          @id @default(cuid())
  jobId        String
  job          LinkAnalysisJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  sitoId       String
  fontePostId  Int
  fonteTitolo  String
  fonteUrl     String
  targetPostId Int
  targetTitolo String
  targetUrl    String
  anchorText   String
  contesto     String
  motivazione  String
  stato        String          @default("pendente") // pendente | approvato | rifiutato | applicato | errore
  appliedAt    DateTime?
  errore       String?
  creatoIl     DateTime        @default(now())

  @@index([jobId])
  @@index([sitoId])
}
